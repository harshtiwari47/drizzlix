# Public client variables (visible in browser bundle)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_API_URL=/api

# Do NOT put private keys behind VITE_.
# Move Gemini calls to backend and store the private key server-side.
# Example server env variables (set in Vercel project settings):
# MONGO_URI=mongodb+srv://...
# JWT_SECRET=replace-with-long-random-secret
# GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# GEMINI_API_KEY=server-only-key
# APP_ORIGIN=https://drizzlix.vercel.app
